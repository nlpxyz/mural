{
  "name": "mural-service",
  "version": "0.1.0",
  "private": true,
  "packageManager": "yarn@4.9.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/src/server.js",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:migrate": "dotenv -e .env -- prisma migrate dev --schema prisma/schema.prisma",
    "db:push": "dotenv -e .env -- prisma db push --schema prisma/schema.prisma",
    "db:studio": "dotenv -e .env -- prisma studio --schema prisma/schema.prisma",
    "postinstall": "prisma generate --schema prisma/schema.prisma",
    "db:seed": "dotenv -e .env -- tsx prisma/seed.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.14.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "viem": "2.38.0",
    "zod": "4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "dotenv-cli": "7.4.2",
    "eslint": "^9.0.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^15.0.0",
    "prettier": "3.4.2",
    "prisma": "6.14.0",
    "tsx": "4.20.5",
    "typescript": "5.8.3"
  }
}
