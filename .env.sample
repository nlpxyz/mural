NODE_ENV=development
PORT=3000

DATABASE_URL=postgresql://user:password@localhost:5432/mural_service

# MuralPay — read key for accounts + transactions
MURAL_API_KEY=

# MuralPay — transfer key for creating + executing payouts
MURAL_TRANSFER_API_KEY=

# Vercel Cron Job auth secret (set same value in Vercel project env)
CRON_SECRET=

# Static secret for merchant endpoints (x-api-key header)
MERCHANT_API_KEY=
